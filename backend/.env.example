# Required
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/notesdb
SECRET_KEY=change-me-at-least-32-chars
GEMINI_API_KEY=your-gemini-api-key-here

# Optional with defaults
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
BCRYPT_ROUNDS=12
MAX_TITLE_LENGTH=500
MAX_CONTENT_LENGTH=100000
RATE_LIMIT_AUTH=5/minute
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app
ABOUT_NAME=Your Name
ABOUT_EMAIL=your@email.com

# Local dev override
DEV_DATABASE_URL=sqlite+aiosqlite:///./dev.db
